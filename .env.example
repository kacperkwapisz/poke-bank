# Copy to .env and fill in values before running docker-compose

# Bearer token for MCP clients (generate with: openssl rand -hex 32)
MCP_API_KEY=your-secret-key-here

# Enable Banking application credentials
# APP_ID is the application UUID from the Enable Banking dashboard (used as JWT kid)
ENABLE_BANKING_APP_ID=your-app-id
# RSA private key PEM string, or path to a PEM file (used to sign JWTs)
ENABLE_BANKING_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----
ENABLE_BANKING_REDIRECT_URI=https://your-domain.com/callback

# AES-256-GCM session encryption key (64 hex chars)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_ENCRYPTION_KEY=your-64-hex-char-key

# Optional: consent validity in days (default: 90)
# CONSENT_VALIDITY_DAYS=90

# Optional: override the Enable Banking API base URL (e.g. for sandbox)
# ENABLE_BANKING_BASE=https://api.tilisy.com

# Optional: rate limiting (requests per minute per IP)
# RATE_LIMIT_GET_RPM=30
# RATE_LIMIT_POST_RPM=120

# Optional: webhook URL to notify Poke when a bank account is connected
# POKE_WEBHOOK_URL=https://poke.com/api/v1/inbound/api-message
# POKE_API_KEY=your-poke-api-key

# Optional: exposed port on the host
# HOST_PORT=3000
